generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// BetterAuth required models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  audios       Audio[]
  imageGenerations ImageGeneration[]

  // App-specific fields
  stripeCustomerId String? @unique
  polarCustomerId  String? @unique

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// Polar.sh subscription tracking
model Subscription {
  id                   String    @id @default(cuid())
  polarSubscriptionId  String    @unique
  polarProductId       String
  userId               String
  status               String
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@map("subscriptions")
}

// Audio model for audio generation
model Audio {
  id                  String   @id @default(cuid())
  userId              String
  title               String?
  content             String?
  audioUrl            String?
  voiceId             String?   // Store selected voice (gemini voice id)
  duration            Int?      // Audio duration in seconds
  fileSize            Int?      // File size in bytes
  status              String?   @default("processing") // processing, ready, failed
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audios")
}

// Image generation model for RunPod integration
model ImageGeneration {
  id                  String   @id @default(cuid())
  userId              String
  originalPrompt      String   // User's original prompt
  finalPrompt         String   // Final prompt sent to API (after style processing)
  styleName           String?  // Name of selected style (if any)
  negativePrompt      String?
  size                String   @default("1024*1024")
  seed                Int      @default(-1)
  imageUrl            String?  // URL of stored image in MinIO
  originalImageUrl    String?  // Original URL from RunPod (expires in 7 days)
  cost                Decimal? // Generation cost from RunPod
  status              String   @default("processing") // processing, ready, failed
  errorMessage        String?  // Error message if failed
  generationTimeMs    Int?     // Time taken for generation
  delayTimeMs         Int?     // Time spent in queue
  workerId            String?  // RunPod worker ID
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("image_generations")
}
